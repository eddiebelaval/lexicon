# ===========================================
# LEXICON - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# -----------------------------
# Neo4j (Graph Database)
# -----------------------------
# Get these from Neo4j Aura: https://neo4j.com/cloud/aura/
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here

# -----------------------------
# PostgreSQL (User Data)
# -----------------------------
# Using Supabase or Railway
DATABASE_URL=postgresql://user:password@host:5432/lexicon

# -----------------------------
# Supabase (Auth + Storage)
# -----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------
# Claude API (AI Search)
# -----------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# -----------------------------
# App Configuration
# -----------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------
# Web Monitoring (Phase 3)
# -----------------------------
# Perplexity API - AI-powered news search
# Get your key at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your-key-here

# NewsAPI - Optional backup news source
# Get your key at: https://newsapi.org/account
NEWSAPI_KEY=your-newsapi-key-here

# Cron Job Authentication
# Generate a random secret for securing cron endpoints
CRON_SECRET=your-random-secret-here

# -----------------------------
# Email Delivery (Phase 4)
# -----------------------------
# Resend - Transactional email
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_your-key-here

# Email sender address (must be verified domain in Resend)
RESEND_FROM_EMAIL=digests@yourdomain.com

# -----------------------------
# Optional: Analytics
# -----------------------------
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
